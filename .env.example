# ─────────────────────────────────────────────────────────────
# RWS Creative — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# Supabase — create a project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Contact form — add your preferred handler URL (Formspree, Resend, etc.)
# CONTACT_FORM_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID
